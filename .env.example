# Base URL of the Radar Kleszczy backend (Fastify API).
# Public deployment: https://radar-kleszczy-api.onrender.com
# Local backend:     http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=https://radar-kleszczy-api.onrender.com

# Base path when hosted under a sub-path (GitHub *project* Pages:
# https://<user>.github.io/<repo>/  ->  set this to "/<repo>").
# Leave empty for local dev, a user page, or a custom domain at the root.
# The GitHub Actions workflow sets this automatically on deploy.
NEXT_PUBLIC_BASE_PATH=

# Cloudflare Turnstile site key used by the report form widget.
# Default below is Cloudflare's official test key that always passes and is safe
# for local development. Replace with your real site key in production.
# The matching secret lives on the BACKEND (TURNSTILE_SECRET_KEY).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
